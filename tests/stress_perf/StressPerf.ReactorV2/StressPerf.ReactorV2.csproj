<Project Sdk="Microsoft.NET.Sdk">
  <!--
    Spec 047 Phase 0 — V2 scaffolding. Intentionally identical to
    StressPerf.Reactor at Phase-0 freeze (so V2 numbers ≈ Today numbers).
    Phase 1+ work shows up as the delta. Project name and AssemblyName
    differ so both binaries can coexist side-by-side in a comparison run.
  -->
  <PropertyGroup>
    <OutputType>WinExe</OutputType>
    <TargetFramework>net10.0-windows10.0.22621.0</TargetFramework>
    <Platforms>x64;ARM64</Platforms>
    <RootNamespace>StressPerf.ReactorV2</RootNamespace>
    <AssemblyName>StressPerf.ReactorV2</AssemblyName>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <UseWinUI>true</UseWinUI>
    <WindowsPackageType>None</WindowsPackageType>
    <PublishAot>true</PublishAot>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.WindowsAppSDK" Version="$(WindowsAppSDKVersion)" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\StressPerf.Shared\StressPerf.Shared.csproj" />
    <ProjectReference Include="..\..\..\src\Reactor\Reactor.csproj" />
  </ItemGroup>
</Project>
