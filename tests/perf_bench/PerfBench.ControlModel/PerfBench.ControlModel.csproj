<Project Sdk="Microsoft.NET.Sdk">
  <!--
    Spec 047 §15.3 Phase 0 micro suite scaffold.

    Hosts M1 through M13 across three variants (Direct, ReactorToday, ReactorV2).
    At Phase 0 freeze, ReactorV2 mirrors ReactorToday so the V2 path delegates;
    Phase 1+ work shows up as the V2 vs Today delta.

    Shape: WinUI app (some benches construct UIElements which require a
    DispatcherQueue), driven by a CLI switch:
      PerfBench.ControlModel.exe \-\-test M1 \-\-variant Direct \-\-iterations 10000
    Output: one JSON-Lines row per (test, variant, repetition) into
    results.jsonl, consumed by the spec 15.6 reporting aggregator.

    Uses the existing PerfBench.Shared infrastructure rather than
    BenchmarkDotNet. BDN separate-process isolation conflicts with WinUI's
    single-DispatcherQueue requirement; the runner produces BDN-comparable
    stats (mean ns, 95% CI, alloc bytes, GC counts) from N repetitions.
  -->
  <PropertyGroup>
    <OutputType>WinExe</OutputType>
    <TargetFramework>net10.0-windows10.0.22621.0</TargetFramework>
    <Platforms>x64;ARM64</Platforms>
    <RootNamespace>PerfBench.ControlModel</RootNamespace>
    <AssemblyName>PerfBench.ControlModel</AssemblyName>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <AllowUnsafeBlocks>true</AllowUnsafeBlocks>
    <UseWinUI>true</UseWinUI>
    <WindowsPackageType>None</WindowsPackageType>
  </PropertyGroup>
  <ItemGroup>
    <PackageReference Include="Microsoft.WindowsAppSDK" Version="$(WindowsAppSDKVersion)" />
  </ItemGroup>
  <ItemGroup>
    <ProjectReference Include="..\PerfBench.Shared\PerfBench.Shared.csproj" />
    <ProjectReference Include="..\..\..\src\Reactor\Reactor.csproj" />
  </ItemGroup>
  <ItemGroup>
    <FrameworkReference Include="Microsoft.WindowsDesktop.App" />
  </ItemGroup>
</Project>
