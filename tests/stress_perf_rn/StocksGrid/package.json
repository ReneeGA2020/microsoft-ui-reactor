{
  "name": "StocksGrid",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "windows": "npx @react-native-community/cli run-windows",
    "windows-debug": "react-native run-windows --arch x64",
    "lint": "eslint .",
    "start": "react-native start",
    "test": "jest",
    "test:windows": "jest --config jest.config.windows.js"
  },
  "dependencies": {
    "react": "19.1.1",
    "react-native": "0.82.0"
  },
  "devDependencies": {
    "@babel/core": "^7.25.2",
    "@babel/preset-env": "^7.25.3",
    "@babel/runtime": "^7.25.0",
    "@react-native-community/cli": "20.0.0",
    "@react-native/babel-preset": "0.82.0",
    "@react-native/eslint-config": "0.82.0",
    "@react-native/metro-config": "0.82.0",
    "@react-native/typescript-config": "0.82.0",
    "@rnx-kit/jest-preset": "^0.1.17",
    "@types/jest": "^29.5.13",
    "@types/react": "^19.1.1",
    "@types/react-test-renderer": "^19.1.0",
    "eslint": "^8.19.0",
    "jest": "^29.6.3",
    "prettier": "2.8.8",
    "react-native-windows": "^0.82.5",
    "react-test-renderer": "19.1.1",
    "typescript": "^5.8.3"
  },
  "engines": {
    "node": ">=20"
  },
  "react-native-windows": {
    "init-windows": {
      "name": "StocksGrid",
      "namespace": "StocksGrid",
      "template": "cpp-app"
