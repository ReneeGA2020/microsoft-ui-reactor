<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <OutputType>WinExe</OutputType>
    <TargetFramework>net10.0-windows10.0.22621.0</TargetFramework>
    <Platforms>x64;ARM64</Platforms>
    <RootNamespace>BlankReactor</RootNamespace>
    <AssemblyName>BlankReactor</AssemblyName>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <UseWinUI>true</UseWinUI>
    <WindowsPackageType>None</WindowsPackageType>
    <!-- AOT off: NativeAOT trims the EventSource subclass even with manifest
         events, producing zero ETW emissions. -->
    <PublishAot>false</PublishAot>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.WindowsAppSDK" Version="$(WindowsAppSDKVersion)" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\..\..\src\Reactor\Reactor.csproj" />
  </ItemGroup>

  <ItemGroup>
    <Compile Include="..\Common\BenchmarkTracing.cs" Link="Common\BenchmarkTracing.cs" />
    <Compile Include="..\Common\BlankPerfMetrics.cs" Link="Common\BlankPerfMetrics.cs" />
  </ItemGroup>
</Project>
