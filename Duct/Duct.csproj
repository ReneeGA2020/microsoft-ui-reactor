<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net8.0-windows10.0.22621.0</TargetFramework>
    <Platforms>x64;ARM64</Platforms>
    <RootNamespace>Duct</RootNamespace>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <UseWinUI>true</UseWinUI>
    <WindowsSdkPackageVersion>10.0.22621.52</WindowsSdkPackageVersion>
    <AllowUnsafeBlocks>true</AllowUnsafeBlocks>
    <!-- Library projects must not produce MsixContent — the hosting app handles native DLLs -->
    <WindowsAppSDKSelfContained>false</WindowsAppSDKSelfContained>
  </PropertyGroup>

  <ItemGroup>
    <InternalsVisibleTo Include="Duct.Tests" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.WindowsAppSDK" Version="$(WindowsAppSDKVersion)" />
  </ItemGroup>

  <!-- ═══════════════════════════════════════════════════════════════════
       Native Rust differ — built by cargo, DLL copied to output
       ═══════════════════════════════════════════════════════════════════ -->
  <PropertyGroup>
    <RustCrateDir>$(MSBuildThisFileDirectory)Native\differ</RustCrateDir>
    <!-- Map MSBuild Platform → Rust target triple -->
    <RustTarget Condition="'$(Platform)' == 'ARM64' Or '$(Platform)' == 'arm64'">aarch64-pc-windows-msvc</RustTarget>
    <RustTarget Condition="'$(Platform)' == 'x64'">x86_64-pc-windows-msvc</RustTarget>
    <!-- Fallback: detect from RuntimeIdentifier or PROCESSOR_ARCHITECTURE when Platform is AnyCPU/unset -->
    <RustTarget Condition="'$(RustTarget)' == '' And '$(RuntimeIdentifier)' == 'win-arm64'">aarch64-pc-windows-msvc</RustTarget>
    <RustTarget Condition="'$(RustTarget)' == '' And '$(RuntimeIdentifier)' == 'win-x64'">x86_64-pc-windows-msvc</RustTarget>
    <RustTarget Condition="'$(RustTarget)' == '' And '$(PROCESSOR_ARCHITECTURE)' == 'ARM64'">aarch64-pc-windows-msvc</RustTarget>
    <RustTarget Condition="'$(RustTarget)' == '' And '$(PROCESSOR_ARCHITECTURE)' == 'AMD64'">x86_64-pc-windows-msvc</RustTarget>
    <RustProfile Condition="'$(Configuration)' == 'Release'">release</RustProfile>
    <RustProfile Condition="'$(Configuration)' != 'Release'">dev</RustProfile>
    <RustProfileDir Condition="'$(RustProfile)' == 'release'">release</RustProfileDir>
    <RustProfileDir Condition="'$(RustProfile)' != 'release'">debug</RustProfileDir>
    <RustDllPath>$(RustCrateDir)\target\$(RustTarget)\$(RustProfileDir)\viewdiffer.dll</RustDllPath>
  </PropertyGroup>

  <Target Name="BuildRustDiffer" BeforeTargets="BeforeBuild"
          Inputs="$(RustCrateDir)\src\**\*.rs;$(RustCrateDir)\Cargo.toml"
          Outputs="$(RustDllPath)">
    <Exec Command="cargo build --manifest-path &quot;$(RustCrateDir)\Cargo.toml&quot; --target $(RustTarget) --profile $(RustProfile)"
          ConsoleToMsBuild="true" />
  </Target>

  <Target Name="CopyRustDll" AfterTargets="BuildRustDiffer" BeforeTargets="BeforeBuild"
          Condition="Exists('$(RustDllPath)')">
    <Copy SourceFiles="$(RustDllPath)" DestinationFolder="$(OutputPath)" SkipUnchangedFiles="true" />
  </Target>

  <!-- Also include in publish output -->
  <ItemGroup Condition="Exists('$(RustDllPath)')">
    <None Include="$(RustDllPath)" CopyToOutputDirectory="PreserveNewest" Link="viewdiffer.dll" />
  </ItemGroup>

</Project>
