<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net9.0-windows10.0.22621.0</TargetFramework>
    <Platforms>x64;ARM64</Platforms>
    <RootNamespace>Duct</RootNamespace>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <UseWinUI>true</UseWinUI>
    <AllowUnsafeBlocks>true</AllowUnsafeBlocks>
    <WindowsAppSDKSelfContained>false</WindowsAppSDKSelfContained>
  </PropertyGroup>

  <ItemGroup>
    <InternalsVisibleTo Include="Duct.Tests" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.WindowsAppSDK" Version="$(WindowsAppSDKVersion)" />
    <PackageReference Include="System.Drawing.Common" Version="9.0.0" />
    <PackageReference Include="MessageFormat" Version="8.0.0" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\Duct.Localization.Generator\Duct.Localization.Generator.csproj"
                      OutputItemType="Analyzer"
                      ReferenceOutputAssembly="false" />
  </ItemGroup>

  <!-- ═══════════════════════════════════════════════════════════════════
       Localization — .resw files fed to the source generator
       ═══════════════════════════════════════════════════════════════════ -->
  <PropertyGroup>
    <DuctLocDefaultLocale Condition="'$(DuctLocDefaultLocale)' == ''">en-US</DuctLocDefaultLocale>
    <DuctLocStringsPath Condition="'$(DuctLocStringsPath)' == ''">Strings/</DuctLocStringsPath>
  </PropertyGroup>

  <ItemGroup>
    <AdditionalFiles Include="$(DuctLocStringsPath)**/*.resw" Condition="Exists('$(DuctLocStringsPath)')" />
  </ItemGroup>

  <!-- ═══════════════════════════════════════════════════════════════════
       Monaco editor — HTML shell + vendored JS assets (unmodified from npm)
       Copied to output so MonacoEditor control can load them via WebView2.
       ═══════════════════════════════════════════════════════════════════ -->
  <ItemGroup>
    <Content Include="Monaco\monaco-editor.html" CopyToOutputDirectory="PreserveNewest" Link="Monaco\monaco-editor.html" />
    <!-- Use None (not Content) to avoid PRI resource indexer warnings on JS filenames -->
    <None Include="Monaco\Assets\**" CopyToOutputDirectory="PreserveNewest" LinkBase="Monaco\Assets" />
    <Compile Remove="Monaco\Assets\**" />
    <EmbeddedResource Remove="Monaco\Assets\**" />
    <Content Remove="Monaco\Assets\**" />
  </ItemGroup>


</Project>
