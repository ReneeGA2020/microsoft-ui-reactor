<Page
    x:Class="FlexPanelGallery.Pages.GapPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:flex="using:Duct.Flex">

    <ScrollViewer>
        <StackPanel Spacing="16" Padding="24">
            <TextBlock Text="Gap" Style="{StaticResource TitleTextBlockStyle}" />
            <TextBlock Text="ColumnGap and RowGap add spacing between items without using margins." TextWrapping="Wrap" />

            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" CornerRadius="8" Padding="16">
                <StackPanel Spacing="12">
                    <Slider x:Name="ColumnGapSlider" Header="Column Gap" Minimum="0" Maximum="32" Value="8"
                            ValueChanged="GapSlider_ValueChanged" />
                    <Slider x:Name="RowGapSlider" Header="Row Gap" Minimum="0" Maximum="32" Value="8"
                            ValueChanged="GapSlider_ValueChanged" />

                    <Border BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}" BorderThickness="1"
                            MinHeight="200">
                        <flex:FlexPanel x:Name="DemoPanel" Direction="Row" Wrap="Wrap" ColumnGap="8" RowGap="8">
                            <Border Width="80" Height="60" Background="CornflowerBlue" CornerRadius="4" />
                            <Border Width="80" Height="60" Background="MediumSeaGreen" CornerRadius="4" />
                            <Border Width="80" Height="60" Background="Coral" CornerRadius="4" />
                            <Border Width="80" Height="60" Background="MediumPurple" CornerRadius="4" />
                            <Border Width="80" Height="60" Background="DarkOrange" CornerRadius="4" />
                            <Border Width="80" Height="60" Background="SteelBlue" CornerRadius="4" />
                        </flex:FlexPanel>
                    </Border>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</Page>
