<Page
    x:Class="FlexPanelGallery.Pages.AlignItemsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:flex="using:Duct.Flex">

    <ScrollViewer>
        <StackPanel Spacing="16" Padding="24">
            <TextBlock Text="Align Items" Style="{StaticResource TitleTextBlockStyle}" />
            <TextBlock Text="Controls how items are aligned along the cross axis." TextWrapping="Wrap" />

            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" CornerRadius="8" Padding="16">
                <StackPanel Spacing="12">
                    <ComboBox x:Name="AlignCombo" Header="AlignItems" SelectedIndex="0"
                              SelectionChanged="AlignCombo_SelectionChanged">
                        <ComboBoxItem Content="Stretch" Tag="Stretch" />
                        <ComboBoxItem Content="FlexStart" Tag="FlexStart" />
                        <ComboBoxItem Content="Center" Tag="Center" />
                        <ComboBoxItem Content="FlexEnd" Tag="FlexEnd" />
                        <ComboBoxItem Content="Baseline" Tag="Baseline" />
                    </ComboBox>

                    <Border BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}" BorderThickness="1"
                            Height="200">
                        <flex:FlexPanel x:Name="DemoPanel" Direction="Row" AlignItems="Stretch">
                            <Border Width="60" Height="40" Background="CornflowerBlue" CornerRadius="4" />
                            <Border Width="80" Height="80" Background="MediumSeaGreen" CornerRadius="4" />
                            <Border Width="50" Height="60" Background="Coral" CornerRadius="4" />
                        </flex:FlexPanel>
                    </Border>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</Page>
