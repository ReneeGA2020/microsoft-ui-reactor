<Page
    x:Class="FlexPanelGallery.Pages.NestedFlexPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:flex="using:Duct.Flex">

    <ScrollViewer>
        <StackPanel Spacing="16" Padding="24">
            <TextBlock Text="Nested Flex Layouts" Style="{StaticResource TitleTextBlockStyle}" />
            <TextBlock Text="FlexPanels can be nested to compose complex, responsive layouts — just like nested CSS Flexbox."
                       TextWrapping="Wrap" />

            <!-- Example 1: Holy Grail Layout -->
            <TextBlock Text="Holy Grail Layout" Style="{StaticResource SubtitleTextBlockStyle}" Margin="0,8,0,0" />
            <TextBlock Text="Header, footer, and a three-column body: sidebar, content, and aside."
                       TextWrapping="Wrap" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" CornerRadius="8" Padding="16">
                <Border BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}" BorderThickness="1"
                        Height="300">
                    <flex:FlexPanel Direction="Column">
                        <!-- Header -->
                        <Border Height="40" Background="CornflowerBlue" CornerRadius="4,4,0,0">
                            <TextBlock Text="Header" Foreground="White"
                                       HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <!-- Body (row with sidebar, content, aside) -->
                        <flex:FlexPanel Direction="Row" flex:FlexPanel.Grow="1">
                            <Border Width="80" Background="#E8EAF6">
                                <TextBlock Text="Sidebar" Margin="8" TextWrapping="Wrap"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                            </Border>
                            <Border flex:FlexPanel.Grow="1" Background="#F5F5F5">
                                <TextBlock Text="Main Content Area" Margin="12"
                                           Foreground="{ThemeResource TextFillColorPrimaryBrush}" />
                            </Border>
                            <Border Width="80" Background="#E8EAF6">
                                <TextBlock Text="Aside" Margin="8" TextWrapping="Wrap"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                            </Border>
                        </flex:FlexPanel>
                        <!-- Footer -->
                        <Border Height="40" Background="MediumSeaGreen" CornerRadius="0,0,4,4">
                            <TextBlock Text="Footer" Foreground="White"
                                       HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                    </flex:FlexPanel>
                </Border>
            </Border>

            <!-- Example 2: Sidebar Layout -->
            <TextBlock Text="Sidebar + Content" Style="{StaticResource SubtitleTextBlockStyle}" Margin="0,8,0,0" />
            <TextBlock Text="A fixed-width sidebar with a flexible content area that grows to fill remaining space."
                       TextWrapping="Wrap" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" CornerRadius="8" Padding="16">
                <Border BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}" BorderThickness="1"
                        Height="200">
                    <flex:FlexPanel Direction="Row">
                        <!-- Nav sidebar -->
                        <flex:FlexPanel Direction="Column" Width="120" RowGap="4"
                                        FlexPadding="8,8,8,8" flex:FlexPanel.Shrink="0">
                            <Border Height="32" Background="SteelBlue" CornerRadius="4">
                                <TextBlock Text="Dashboard" Foreground="White" VerticalAlignment="Center" Margin="8,0" FontSize="12" />
                            </Border>
                            <Border Height="32" Background="#5C6BC0" CornerRadius="4">
                                <TextBlock Text="Analytics" Foreground="White" VerticalAlignment="Center" Margin="8,0" FontSize="12" />
                            </Border>
                            <Border Height="32" Background="#5C6BC0" CornerRadius="4">
                                <TextBlock Text="Settings" Foreground="White" VerticalAlignment="Center" Margin="8,0" FontSize="12" />
                            </Border>
                            <Border Height="32" Background="#5C6BC0" CornerRadius="4">
                                <TextBlock Text="Profile" Foreground="White" VerticalAlignment="Center" Margin="8,0" FontSize="12" />
                            </Border>
                        </flex:FlexPanel>
                        <!-- Content -->
                        <Border flex:FlexPanel.Grow="1" Background="#FAFAFA" Padding="16">
                            <StackPanel Spacing="8">
                                <TextBlock Text="Content Area" FontWeight="SemiBold" />
                                <TextBlock Text="This area grows to fill all remaining horizontal space."
                                           TextWrapping="Wrap" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                            </StackPanel>
                        </Border>
                    </flex:FlexPanel>
                </Border>
            </Border>

            <!-- Example 3: Card Grid -->
            <TextBlock Text="Card Grid" Style="{StaticResource SubtitleTextBlockStyle}" Margin="0,8,0,0" />
            <TextBlock Text="A wrapping row of cards where each card is itself a column flex container."
                       TextWrapping="Wrap" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" CornerRadius="8" Padding="16">
                <flex:FlexPanel Direction="Row" Wrap="Wrap" ColumnGap="12" RowGap="12">
                    <!-- Card 1 -->
                    <flex:FlexPanel Direction="Column" Width="140" RowGap="4"
                                    FlexPadding="0,0,0,8">
                        <Border Height="80" Background="Coral" CornerRadius="4,4,0,0" />
                        <TextBlock Text="Sunset" FontWeight="SemiBold" Margin="8,4,8,0" />
                        <TextBlock Text="A beautiful sunset over the ocean." FontSize="11" TextWrapping="Wrap"
                                   Margin="8,0" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                    </flex:FlexPanel>
                    <!-- Card 2 -->
                    <flex:FlexPanel Direction="Column" Width="140" RowGap="4"
                                    FlexPadding="0,0,0,8">
                        <Border Height="80" Background="MediumSeaGreen" CornerRadius="4,4,0,0" />
                        <TextBlock Text="Forest" FontWeight="SemiBold" Margin="8,4,8,0" />
                        <TextBlock Text="Dense green canopy in a tropical forest." FontSize="11" TextWrapping="Wrap"
                                   Margin="8,0" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                    </flex:FlexPanel>
                    <!-- Card 3 -->
                    <flex:FlexPanel Direction="Column" Width="140" RowGap="4"
                                    FlexPadding="0,0,0,8">
                        <Border Height="80" Background="CornflowerBlue" CornerRadius="4,4,0,0" />
                        <TextBlock Text="Ocean" FontWeight="SemiBold" Margin="8,4,8,0" />
                        <TextBlock Text="Calm waters stretching to the horizon." FontSize="11" TextWrapping="Wrap"
                                   Margin="8,0" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                    </flex:FlexPanel>
                    <!-- Card 4 -->
                    <flex:FlexPanel Direction="Column" Width="140" RowGap="4"
                                    FlexPadding="0,0,0,8">
                        <Border Height="80" Background="MediumPurple" CornerRadius="4,4,0,0" />
                        <TextBlock Text="Mountains" FontWeight="SemiBold" Margin="8,4,8,0" />
                        <TextBlock Text="Snow-capped peaks under a clear sky." FontSize="11" TextWrapping="Wrap"
                                   Margin="8,0" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                    </flex:FlexPanel>
                </flex:FlexPanel>
            </Border>

            <!-- Example 4: Toolbar -->
            <TextBlock Text="Toolbar with Spacer" Style="{StaticResource SubtitleTextBlockStyle}" Margin="0,8,0,0" />
            <TextBlock Text="A common pattern: left-aligned group, spacer (flex-grow), right-aligned group."
                       TextWrapping="Wrap" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" CornerRadius="8" Padding="16">
                <Border BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}" BorderThickness="1">
                    <flex:FlexPanel Direction="Row" AlignItems="Center" FlexPadding="8,4,8,4" ColumnGap="8">
                        <!-- Left group -->
                        <Border Height="32" Width="32" Background="SteelBlue" CornerRadius="4">
                            <FontIcon Glyph="&#xE700;" Foreground="White" FontSize="14"
                                      HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <TextBlock Text="My Application" FontWeight="SemiBold" VerticalAlignment="Center" />
                        <!-- Spacer -->
                        <Border flex:FlexPanel.Grow="1" />
                        <!-- Right group -->
                        <Border Height="28" CornerRadius="4" Padding="8,0" Background="#E8EAF6">
                            <TextBlock Text="Search..." VerticalAlignment="Center" FontSize="12"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                        </Border>
                        <Border Height="32" Width="32" Background="DarkOrange" CornerRadius="16">
                            <TextBlock Text="JD" Foreground="White" FontSize="11" FontWeight="Bold"
                                       HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                    </flex:FlexPanel>
                </Border>
            </Border>
        </StackPanel>
    </ScrollViewer>
</Page>
