<Page
    x:Class="FlexPanelGallery.Pages.AbsolutePositionPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:flex="using:Duct.Flex">

    <ScrollViewer>
        <StackPanel Spacing="16" Padding="24">
            <TextBlock Text="Absolute Position" Style="{StaticResource TitleTextBlockStyle}" />
            <TextBlock Text="Absolute children are removed from the normal flow and positioned relative to their containing block."
                       TextWrapping="Wrap" />

            <!-- Example 1: Basic absolute positioning -->
            <TextBlock Text="Basic Absolute Positioning" Style="{StaticResource SubtitleTextBlockStyle}" Margin="0,8,0,0" />
            <TextBlock Text="An absolute child positioned with Left=20, Top=20. It does not affect the layout of its siblings."
                       TextWrapping="Wrap" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" CornerRadius="8" Padding="16">
                <Border BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}" BorderThickness="1"
                        Height="200">
                    <flex:FlexPanel Direction="Column">
                        <Border Height="40" Background="CornflowerBlue" CornerRadius="4" Margin="4">
                            <TextBlock Text="Flow child 1" Foreground="White" VerticalAlignment="Center" Margin="8,0" />
                        </Border>
                        <Border flex:FlexPanel.Position="Absolute"
                                flex:FlexPanel.Left="20" flex:FlexPanel.Top="20"
                                Width="120" Height="80"
                                Background="#CC4CAF50" CornerRadius="4">
                            <TextBlock Text="Absolute&#x0a;Left=20, Top=20" Foreground="White"
                                       HorizontalAlignment="Center" VerticalAlignment="Center" TextAlignment="Center" />
                        </Border>
                        <Border Height="40" Background="Coral" CornerRadius="4" Margin="4">
                            <TextBlock Text="Flow child 2 (not pushed down)" Foreground="White" VerticalAlignment="Center" Margin="8,0" />
                        </Border>
                    </flex:FlexPanel>
                </Border>
            </Border>

            <!-- Example 2: Stretch via opposing insets -->
            <TextBlock Text="Stretch with Opposing Insets" Style="{StaticResource SubtitleTextBlockStyle}" Margin="0,8,0,0" />
            <TextBlock Text="Setting both Left+Right or Top+Bottom stretches the child to fill the available space minus the insets."
                       TextWrapping="Wrap" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" CornerRadius="8" Padding="16">
                <Border BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}" BorderThickness="1"
                        Height="200">
                    <flex:FlexPanel Direction="Column">
                        <Border flex:FlexPanel.Position="Absolute"
                                flex:FlexPanel.Left="10" flex:FlexPanel.Right="10"
                                flex:FlexPanel.Top="10" flex:FlexPanel.Bottom="10"
                                Background="#33007ACC" CornerRadius="4"
                                BorderBrush="DodgerBlue" BorderThickness="2">
                            <TextBlock Text="Stretched: all insets = 10" Foreground="DodgerBlue"
                                       HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                    </flex:FlexPanel>
                </Border>
            </Border>

            <!-- Example 3: Corner badges -->
            <TextBlock Text="Corner Badges" Style="{StaticResource SubtitleTextBlockStyle}" Margin="0,8,0,0" />
            <TextBlock Text="Absolute positioning is ideal for overlays, badges, and corner indicators."
                       TextWrapping="Wrap" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" CornerRadius="8" Padding="16">
                <Border BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}" BorderThickness="1"
                        Height="200">
                    <flex:FlexPanel Direction="Row" JustifyContent="Center" AlignItems="Center">
                        <!-- Center content -->
                        <Border Width="160" Height="100" Background="MediumPurple" CornerRadius="8">
                            <TextBlock Text="Card Content" Foreground="White"
                                       HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <!-- Top-left badge -->
                        <Border flex:FlexPanel.Position="Absolute"
                                flex:FlexPanel.Left="8" flex:FlexPanel.Top="8"
                                Width="24" Height="24" CornerRadius="12"
                                Background="Red">
                            <TextBlock Text="1" Foreground="White" FontSize="11" FontWeight="Bold"
                                       HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <!-- Top-right badge -->
                        <Border flex:FlexPanel.Position="Absolute"
                                flex:FlexPanel.Right="8" flex:FlexPanel.Top="8"
                                Width="24" Height="24" CornerRadius="12"
                                Background="DarkOrange">
                            <TextBlock Text="!" Foreground="White" FontSize="11" FontWeight="Bold"
                                       HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <!-- Bottom-right tag -->
                        <Border flex:FlexPanel.Position="Absolute"
                                flex:FlexPanel.Right="8" flex:FlexPanel.Bottom="8"
                                Height="24" CornerRadius="4" Padding="8,0"
                                Background="MediumSeaGreen">
                            <TextBlock Text="NEW" Foreground="White" FontSize="11" FontWeight="Bold"
                                       VerticalAlignment="Center" />
                        </Border>
                    </flex:FlexPanel>
                </Border>
            </Border>

            <!-- Example 4: Interactive positioning -->
            <TextBlock Text="Interactive Positioning" Style="{StaticResource SubtitleTextBlockStyle}" Margin="0,8,0,0" />
            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" CornerRadius="8" Padding="16">
                <StackPanel Spacing="12">
                    <Slider x:Name="LeftSlider" Header="Left" Minimum="0" Maximum="200" Value="50"
                            ValueChanged="PositionSlider_ValueChanged" />
                    <Slider x:Name="TopSlider" Header="Top" Minimum="0" Maximum="150" Value="50"
                            ValueChanged="PositionSlider_ValueChanged" />

                    <Border BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}" BorderThickness="1"
                            Height="200">
                        <flex:FlexPanel x:Name="InteractivePanel" Direction="Row">
                            <Border flex:FlexPanel.Position="Absolute"
                                    x:Name="MovableBox"
                                    flex:FlexPanel.Left="50" flex:FlexPanel.Top="50"
                                    Width="60" Height="60"
                                    Background="SteelBlue" CornerRadius="4">
                                <TextBlock Text="Drag me" Foreground="White" FontSize="11"
                                           HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </Border>
                        </flex:FlexPanel>
                    </Border>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</Page>
