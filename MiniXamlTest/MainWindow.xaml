<Window
    x:Class="MiniXamlTest.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Grid instead of StackPanel so the middle row can stretch -->
    <Grid Background="Red">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Border(Text("Hello, Duct!")).Background("orange") -->
        <Border Grid.Row="0" Background="Orange">
            <TextBlock Text="Hello, Duct!" />
        </Border>

        <!-- Border(Text("Hello, Duct!")).Background("blue").VAlign(VerticalAlignment.Stretch) -->
        <Border Grid.Row="1" Background="Blue" VerticalAlignment="Stretch">
            <TextBlock Text="Hello, Duct!" />
        </Border>

        <!-- Border(Text("Hello, Duct!")).Background("green") -->
        <Border Grid.Row="2" Background="Green">
            <TextBlock Text="Hello, Duct!" />
        </Border>

    </Grid>

</Window>
