<Page
    x:Class="FlexPanelGallery.Pages.DirectionPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:flex="using:Duct.Flex"
    xmlns:yoga="using:Duct.Flex">

    <ScrollViewer>
        <StackPanel Spacing="16" Padding="24">
            <TextBlock Text="Direction" Style="{StaticResource TitleTextBlockStyle}" />
            <TextBlock Text="Controls the main axis along which children are laid out." TextWrapping="Wrap" />

            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" CornerRadius="8" Padding="16">
                <StackPanel Spacing="12">
                    <ComboBox x:Name="DirectionCombo" Header="Direction" SelectedIndex="0"
                              SelectionChanged="DirectionCombo_SelectionChanged">
                        <ComboBoxItem Content="Row" Tag="Row" />
                        <ComboBoxItem Content="RowReverse" Tag="RowReverse" />
                        <ComboBoxItem Content="Column" Tag="Column" />
                        <ComboBoxItem Content="ColumnReverse" Tag="ColumnReverse" />
                    </ComboBox>

                    <Border BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}" BorderThickness="1"
                            MinHeight="200">
                        <flex:FlexPanel x:Name="DemoPanel" Direction="Row">
                            <Border Width="60" Height="60" Background="CornflowerBlue" CornerRadius="4" Margin="4">
                                <TextBlock Text="1" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </Border>
                            <Border Width="80" Height="60" Background="MediumSeaGreen" CornerRadius="4" Margin="4">
                                <TextBlock Text="2" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </Border>
                            <Border Width="50" Height="60" Background="Coral" CornerRadius="4" Margin="4">
                                <TextBlock Text="3" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </Border>
                        </flex:FlexPanel>
                    </Border>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</Page>
