<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>WinExe</OutputType>
    <TargetFramework>net9.0-windows10.0.22621.0</TargetFramework>
    <Platforms>x64;ARM64</Platforms>
    <RootNamespace>ReactorFiles</RootNamespace>
    <AssemblyName>ReactorFiles</AssemblyName>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <UseWinUI>true</UseWinUI>
    <WindowsPackageType>None</WindowsPackageType>
    <AllowUnsafeBlocks>true</AllowUnsafeBlocks>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.WindowsAppSDK" Version="$(WindowsAppSDKVersion)" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\..\..\src\Reactor\Reactor.csproj" />
  </ItemGroup>

  <!-- ═══════════════════════════════════════════════════════════════════
       Native Rust FS enumerator — built by cargo, DLL copied to output
       ═══════════════════════════════════════════════════════════════════ -->
  <PropertyGroup>
    <RustCrateDir>$(MSBuildThisFileDirectory)Native\reactorfs</RustCrateDir>
    <!-- Map MSBuild Platform → Rust target triple -->
    <RustTarget Condition="'$(Platform)' == 'ARM64'">aarch64-pc-windows-msvc</RustTarget>
    <RustTarget Condition="'$(Platform)' == 'x64'">x86_64-pc-windows-msvc</RustTarget>
    <RustProfile Condition="'$(Configuration)' == 'Release'">release</RustProfile>
    <RustProfile Condition="'$(Configuration)' != 'Release'">dev</RustProfile>
    <RustProfileDir Condition="'$(RustProfile)' == 'release'">release</RustProfileDir>
    <RustProfileDir Condition="'$(RustProfile)' != 'release'">debug</RustProfileDir>
    <RustDllPath>$(RustCrateDir)\target\$(RustTarget)\$(RustProfileDir)\reactorfs.dll</RustDllPath>
  </PropertyGroup>

  <Target Name="BuildRustFs" BeforeTargets="BeforeBuild"
          Inputs="$(RustCrateDir)\src\**\*.rs;$(RustCrateDir)\Cargo.toml"
          Outputs="$(RustDllPath)">
    <Exec Command="cargo build --manifest-path &quot;$(RustCrateDir)\Cargo.toml&quot; --target $(RustTarget) --profile $(RustProfile)"
          ConsoleToMsBuild="true" />
  </Target>

  <Target Name="CopyRustDll" AfterTargets="BuildRustFs" BeforeTargets="BeforeBuild"
          Condition="Exists('$(RustDllPath)')">
    <Copy SourceFiles="$(RustDllPath)" DestinationFolder="$(OutputPath)" SkipUnchangedFiles="true" />
  </Target>

  <!-- Also include in publish output -->
  <ItemGroup Condition="Exists('$(RustDllPath)')">
    <None Include="$(RustDllPath)" CopyToOutputDirectory="PreserveNewest" Link="reactorfs.dll" />
  </ItemGroup>

</Project>
