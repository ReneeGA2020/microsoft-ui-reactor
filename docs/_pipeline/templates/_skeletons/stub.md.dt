# Skeleton: stub tier (spec 041 §6.1).
#
# This file is a scaffold — copy it to docs/_pipeline/templates/<topic>.md.dt
# and replace every {{REPLACE_ME}} token with real content. The compile
# pipeline excludes everything under _skeletons/ from template discovery, so
# this file does not produce a guide page even though its tier-lint would
# fail (placeholders are not real content).
#
# Required structural elements for the stub tier:
#   - front-matter (title, app, order, audience, goal, tier)
#   - one `#` title heading
#   - at least one paragraph
#   - a link to the AI author skill so the surface area stays discoverable
#
# Anything beyond this is optional. Stubs are placeholders, not content;
# keep them honest — no fake examples, no padding prose.
title: "{{REPLACE_ME: human-readable title}}"
app: {{REPLACE_ME: topic-id, matches the file basename}}
