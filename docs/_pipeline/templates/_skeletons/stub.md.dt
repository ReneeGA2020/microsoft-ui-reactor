audience: {{REPLACE_ME: beginner|intermediate|advanced}}
goal: |
  {{REPLACE_ME: one-sentence "Coming soon — this page documents X."
  description; the AI Author Skill expands this into the full page when
  the stub is promoted.}}
tier: stub
---

